# Git
.git

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Data files
*.npy
*.npz
*.pkl
*.pickle
*.h5
*.hdf5

# Model weights
*.pth
*.pt

# Legacy/Temp
*copy*
/analysis
/toy
/v0
/v1
/v2
state_data
figs*

# Model files (large)
/trained_models/*
!/trained_models/README.md
!/trained_models/.gitkeep

# Data (configurable)
/data/intermediate/*
!/data/intermediate/.gitkeep
# Keep raw and processed data READMEs
!/data/*/README.md

# 04-03: Brain2021Code raw data (Nassar/Waltz/Albrecht/Gold/Frank, Brain 2021).
# 158 MB unzipped; lives at data/raw/Brain2021Code/. Not committed — re-extract
# from the upstream zip if needed. Source URL noted in 04-RESEARCH.md.
/data/raw/Brain2021Code/

# Output directories
/output/*
!/output/.gitkeep
# Keep small circuit inference artifacts (validation JSON + best latent weights + plots)
!/output/circuit_analysis/
/output/circuit_analysis/*
!/output/circuit_analysis/*.json
!/output/circuit_analysis/*.pt
!/output/circuit_analysis/*.png
# Wave A n_latent sweep tree (per-rank ensemble outputs + Pareto aggregates)
!/output/circuit_analysis/n_latent_sweep/
!/output/circuit_analysis/n_latent_sweep/**
# 03-05 masked-loss sweep tree (parallel to Wave A, per-rank + aggregates)
!/output/circuit_analysis/n_latent_sweep_masked/
!/output/circuit_analysis/n_latent_sweep_masked/**
# Per-context diagnostic fits (Plan 03-06)
!/output/circuit_analysis/per_context/
!/output/circuit_analysis/per_context/**
# Re-ignore intermediate scratch inside the sweep tree
/output/circuit_analysis/**/.regen.lock
# Re-ignore smoke-test outputs anywhere (1-init/--quick artifacts, not canonical)
/output/circuit_analysis/**/smoke_test*/

# Canonical RNN checkpoints + provenance metadata (small, named, reproducible).
# These are INPUTS to circuit analysis — committing them lets collaborators run
# scripts/data_pipeline/08_infer_latent_circuits.py without retraining or
# scp'ing from the cluster. The autopush job (cluster/99_push_results.slurm)
# stages these alongside output/circuit_analysis/. The 22MB circuit_data.npz
# stays gitignored — too large for raw git; promote to LFS / DVC if needed.
!/data/processed/rnn_behav/model_context_dm_dual.pth
!/data/processed/rnn_behav/circuit_data_metadata.json
!/data/processed/rnn_behav/metadata.json
# 03-05: track canonical circuit_data.npz so cluster can git pull it
# (cluster assertion requires task_active_mask when MASKED=1; stale npz
#  would trigger fallback regen WITHOUT the mask key)
!/data/processed/rnn_behav/circuit_data.npz
# 03-05: pre-masked backup — fixed name so it never pollutes git status
data/processed/rnn_behav/circuit_data.npz.pre_masked_backup

# 04-04a: RNN cohort manifest is committed (consumer-facing schema for 04-04b);
# parquet stays local (regenerable from script in ~80 min and large enough
# that LFS would be more appropriate if shared).
!/data/processed/rnn_cohort/
!/data/processed/rnn_cohort/cohort_manifest.json
/data/processed/rnn_cohort/*.parquet

/figures/*
!/figures/.gitkeep
# 04-04a: rnn_cohort sanity figure (Kumar 2025 Fig. 2 replication)
!/figures/rnn_cohort/
!/figures/rnn_cohort/*.png
!/figures/rnn_cohort/*.svg

# Cluster log bulk — keep repo lean, logs live on the cluster
/cluster/logs/*.out
/cluster/logs/*.err
/cluster/logs/gpu_stats_*.csv
!/cluster/logs/.gitkeep

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Environment
.env
.venv
env/
venv/
ENV/
